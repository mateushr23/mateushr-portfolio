# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Anthropic (used by the scheduled sync agent)
ANTHROPIC_API_KEY=

# GitHub API (read-only, public repo listing)
GITHUB_USERNAME=mateushr23
GITHUB_TOKEN=

# Admin sync endpoint (POST /api/admin/sync-repos bearer token)
CRON_SECRET=

# Admin allowlist — comma-separated list of emails permitted to access /admin
# (case-insensitive). Leave empty to lock down /admin entirely.
SUPABASE_ADMIN_ALLOWLIST=

# Public site URL — used by sitemap.ts, robots.ts, and metadataBase in
# layout.tsx to resolve absolute URLs for SEO. Optional; defaults to
# https://mateushr-portfolio.vercel.app when unset. Set this on preview
# deploys and custom domains so generated meta tags don't leak the
# production alias.
NEXT_PUBLIC_SITE_URL=
